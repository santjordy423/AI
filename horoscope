<!DOCTYPE html>

<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=5.0">
<title>統合占術レポート｜1971.04.24</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Shippori+Mincho:wght@400;500;600;700&family=Cardo:ital@0;1&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#1a1814;
    --ink-soft:#3a342c;
    --paper:#f4ede0;
    --paper-deep:#ebe0cc;
    --gold:#a8814a;
    --gold-deep:#7a5a30;
    --rouge:#8c3a3a;
    --rouge-deep:#5e2424;
    --sage:#6b7a5a;
    --line:rgba(26,24,20,0.18);
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-text-size-adjust:100%}
  html,body{
    background:#2a2620;
    color:var(--ink);
    font-family:'Shippori Mincho','Cardo',serif;
    line-height:1.85;
    font-feature-settings:"palt";
    overflow-x:hidden;
  }

.page{
width:100%;
max-width:560px;
margin:0 auto 16px;
background:var(–paper);
background-image:
radial-gradient(ellipse at top left, rgba(168,129,74,0.08), transparent 50%),
radial-gradient(ellipse at bottom right, rgba(140,58,58,0.06), transparent 50%),
url(“data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.4 0 0 0 0 0.3 0 0 0 0 0.2 0 0 0 0.04 0'/></filter><rect width='200' height='200' filter='url(%23n)'/></svg>”);
padding:48px 24px;
position:relative;
box-shadow:0 12px 40px rgba(0,0,0,0.4);
}

.page::before{
content:””;
position:absolute;
inset:12px;
border:1px solid var(–line);
pointer-events:none;
}
.page::after{
content:””;
position:absolute;
inset:16px;
border-top:1px solid rgba(168,129,74,0.4);
border-bottom:1px solid rgba(168,129,74,0.4);
pointer-events:none;
}

/* ===== COVER ===== */
.cover{padding:60px 24px 50px;text-align:center}
.cover .glyph{
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-size:13px;
letter-spacing:0.4em;
color:var(–gold-deep);
text-transform:uppercase;
margin-bottom:32px;
}
.cover h1{
font-family:‘Shippori Mincho’,serif;
font-weight:600;
font-size:38px;
letter-spacing:0.12em;
line-height:1.4;
margin-bottom:8px;
color:var(–ink);
}
.cover h1 em{
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-weight:400;
color:var(–rouge-deep);
font-size:46px;
letter-spacing:0;
}
.cover .sub{
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-size:18px;
color:var(–ink-soft);
margin-bottom:36px;
letter-spacing:0.04em;
line-height:1.5;
}
.cover .sigil{
font-size:26px;
color:var(–gold);
margin:24px auto;
letter-spacing:0.3em;
}
.cover .lead{
font-family:‘Cardo’,serif;
font-style:italic;
font-size:14px;
color:var(–ink-soft);
margin:0 auto 28px;
line-height:1.8;
}
.cover .meta{
border:1px solid var(–gold);
padding:18px 20px;
margin-top:24px;
background:rgba(244,237,224,0.6);
}
.cover .meta-row{
display:flex;
justify-content:space-between;
gap:16px;
font-size:13px;
margin:6px 0;
letter-spacing:0.05em;
}
.cover .meta-row span:first-child{
color:var(–gold-deep);
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-size:13px;
}

/* ===== SECTION HEADERS ===== */
.section-num{
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-size:64px;
color:rgba(168,129,74,0.18);
line-height:0.8;
position:absolute;
top:36px;
right:28px;
z-index:0;
}
.section-label{
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-size:12px;
letter-spacing:0.35em;
color:var(–gold-deep);
text-transform:uppercase;
margin-bottom:6px;
}
h2.section-title{
font-family:‘Shippori Mincho’,serif;
font-weight:600;
font-size:26px;
letter-spacing:0.1em;
line-height:1.4;
margin-bottom:6px;
color:var(–ink);
position:relative;
z-index:1;
}
.section-rule{
width:48px;
height:1px;
background:var(–gold);
margin:14px 0 24px;
}

/* ===== CONTENT BLOCKS ===== */
.block{
margin-bottom:24px;
position:relative;
z-index:1;
}
h3{
font-family:‘Shippori Mincho’,serif;
font-weight:600;
font-size:16px;
letter-spacing:0.12em;
margin-bottom:10px;
color:var(–rouge-deep);
display:flex;
align-items:center;
gap:10px;
}
h3::before{
content:””;
width:18px;
height:1px;
background:var(–rouge-deep);
flex-shrink:0;
}

ul.refined{
list-style:none;
padding-left:0;
}
ul.refined li{
padding:9px 0 9px 18px;
border-bottom:1px dashed var(–line);
position:relative;
font-size:13px;
line-height:1.85;
}
ul.refined li:last-child{border-bottom:none}
ul.refined li::before{
content:“◆”;
position:absolute;
left:0;
top:11px;
color:var(–gold);
font-size:9px;
}
ul.refined li strong{
color:var(–ink);
font-weight:600;
letter-spacing:0.03em;
}

.quote{
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-size:15px;
color:var(–ink-soft);
line-height:1.7;
padding:16px 18px;
border-left:2px solid var(–gold);
background:rgba(168,129,74,0.06);
margin:18px 0;
}
.quote strong{
font-family:‘Shippori Mincho’,serif;
font-style:normal;
color:var(–ink);
}

p.intro{
font-size:13px;
line-height:1.95;
margin:14px 0 24px;
color:var(–ink-soft);
}
p.intro strong{color:var(–ink)}

/* ===== KEYWORD BANNER ===== */
.keyword-banner{
background:linear-gradient(135deg,var(–rouge-deep) 0%,var(–rouge) 100%);
color:var(–paper);
padding:22px 22px;
margin:22px 0;
position:relative;
overflow:hidden;
}
.keyword-banner::before{
content:””;
position:absolute;
top:0;right:0;bottom:0;
width:60px;
background:linear-gradient(45deg,transparent 49%,rgba(244,237,224,0.15) 50%,transparent 51%);
background-size:6px 6px;
}
.keyword-banner .kw-label{
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-size:11px;
letter-spacing:0.3em;
opacity:0.7;
margin-bottom:6px;
}
.keyword-banner .kw-title{
font-family:‘Shippori Mincho’,serif;
font-size:20px;
font-weight:600;
letter-spacing:0.06em;
line-height:1.45;
}
.keyword-banner .kw-en{
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-size:13px;
margin-top:8px;
opacity:0.85;
line-height:1.5;
}

/* ===== DATA STRIP - vertical on mobile ===== */
.data-strip{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:0;
border:1px solid var(–line);
margin:20px 0;
}
.data-strip > div{
padding:14px 8px;
text-align:center;
border-right:1px solid var(–line);
}
.data-strip > div:last-child{border-right:none}
.data-strip .ds-label{
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-size:10px;
letter-spacing:0.2em;
color:var(–gold-deep);
margin-bottom:5px;
}
.data-strip .ds-value{
font-family:‘Shippori Mincho’,serif;
font-size:13px;
font-weight:600;
letter-spacing:0.04em;
color:var(–ink);
line-height:1.4;
}
.data-strip .ds-en{
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-size:10px;
color:var(–ink-soft);
margin-top:4px;
line-height:1.3;
}

/* ===== LIFE STAGE ===== */
.life-stage{
border:1px solid var(–line);
padding:18px 18px;
margin-bottom:14px;
background:rgba(255,255,255,0.3);
position:relative;
}
.life-stage.peak{
background:linear-gradient(135deg,rgba(168,129,74,0.18),rgba(140,58,58,0.08));
border-color:var(–gold);
}
.life-stage-head{
display:flex;
justify-content:space-between;
align-items:flex-end;
margin-bottom:12px;
padding-bottom:10px;
border-bottom:1px solid var(–line);
flex-wrap:wrap;
gap:8px;
}
.life-age{
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-size:24px;
color:var(–ink);
letter-spacing:0.04em;
line-height:1.2;
}
.life-age small{
font-size:11px;
letter-spacing:0.2em;
color:var(–gold-deep);
margin-left:8px;
font-style:normal;
display:inline-block;
}
.stars{
font-size:14px;
letter-spacing:0.15em;
color:var(–rouge);
white-space:nowrap;
}
.stars .off{color:var(–line)}
.life-theme{
font-family:‘Shippori Mincho’,serif;
font-size:14px;
font-weight:600;
color:var(–rouge-deep);
letter-spacing:0.05em;
margin-bottom:12px;
line-height:1.5;
}
.life-stage dl{
display:grid;
grid-template-columns:64px 1fr;
gap:6px 10px;
font-size:12px;
}
.life-stage dt{
color:var(–gold-deep);
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
letter-spacing:0.08em;
font-size:10px;
padding-top:3px;
}
.life-stage dd{line-height:1.7}

/* ===== MONTHS - one column on mobile ===== */
.month-grid{
display:grid;
grid-template-columns:1fr;
gap:10px;
}
.month-card{
border:1px solid var(–line);
padding:14px 16px;
background:rgba(255,255,255,0.35);
position:relative;
}
.month-card.peak{
background:linear-gradient(135deg,rgba(168,129,74,0.12),rgba(140,58,58,0.06));
border-color:var(–gold);
}
.month-head{
display:flex;
justify-content:space-between;
align-items:baseline;
margin-bottom:8px;
padding-bottom:6px;
border-bottom:1px dotted var(–line);
}
.month-num{
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-size:26px;
line-height:1;
color:var(–ink);
}
.month-num small{
font-size:11px;
color:var(–gold-deep);
letter-spacing:0.2em;
margin-left:5px;
font-style:normal;
}
.month-stars{font-size:11px;color:var(–rouge);letter-spacing:0.1em}
.month-stars .off{color:var(–line)}
.month-theme{
font-weight:600;
font-size:13px;
margin:6px 0;
color:var(–rouge-deep);
letter-spacing:0.04em;
}
.month-card p{font-size:11px;line-height:1.7;margin:3px 0}
.month-card .label{
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
color:var(–gold-deep);
font-size:9px;
letter-spacing:0.15em;
display:inline-block;
width:32px;
}
.month-advice{
margin-top:8px;
padding-top:6px;
border-top:1px dotted var(–line);
font-style:italic;
font-family:‘Cardo’,serif;
color:var(–ink-soft);
font-size:11px;
}

/* ===== TWO COL → SINGLE COL on mobile ===== */
.grid-2{
display:grid;
grid-template-columns:1fr;
gap:20px;
}

/* ===== CLOSING ===== */
.closing{
text-align:center;
padding:32px 18px;
background:linear-gradient(180deg,rgba(168,129,74,0.08),rgba(140,58,58,0.05));
border-top:1px solid var(–gold);
border-bottom:1px solid var(–gold);
margin-top:24px;
}
.closing .key{
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-size:12px;
letter-spacing:0.35em;
color:var(–gold-deep);
margin-bottom:18px;
}
.closing h2{
font-family:‘Shippori Mincho’,serif;
font-size:20px;
font-weight:600;
letter-spacing:0.07em;
line-height:1.6;
color:var(–ink);
margin-bottom:20px;
}
.closing h2 em{
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
color:var(–rouge-deep);
font-weight:400;
font-size:24px;
display:block;
margin-top:6px;
}
.closing p{
font-size:13px;
line-height:1.95;
margin:0;
}

.glyph-deco{
text-align:center;
font-size:18px;
color:var(–gold);
letter-spacing:0.6em;
margin:24px 0;
opacity:0.6;
}

.final-message{
margin-top:32px;
text-align:center;
}
.final-message .label{
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-size:12px;
color:var(–gold-deep);
letter-spacing:0.35em;
margin-bottom:18px;
}
.final-message p{
font-family:‘Shippori Mincho’,serif;
font-size:14px;
line-height:2;
color:var(–ink);
letter-spacing:0.04em;
}
.final-message em{
color:var(–rouge-deep);
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-size:18px;
display:block;
margin:10px 0 4px;
}
.final-message .jp-final{
font-size:13px;
color:var(–ink-soft);
}

.signature{
text-align:center;
margin-top:24px;
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
color:var(–gold-deep);
font-size:11px;
letter-spacing:0.25em;
line-height:1.8;
}

/* page footer */
.page-footer{
text-align:center;
margin-top:30px;
padding-top:14px;
border-top:1px solid var(–line);
font-family:‘Cormorant Garamond’,serif;
font-style:italic;
font-size:11px;
letter-spacing:0.25em;
color:var(–gold-deep);
}
.page-footer .num{
display:inline-block;
margin:0 10px;
color:var(–ink);
}

/* tablet & up */
@media (min-width:600px){
.page{padding:64px 48px;margin-bottom:24px}
.cover h1{font-size:54px}
.cover h1 em{font-size:62px}
h2.section-title{font-size:34px}
.section-num{font-size:88px}
ul.refined li{font-size:14px}
.grid-2{grid-template-columns:1fr 1fr}
